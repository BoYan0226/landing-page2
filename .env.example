# Local development environment.
#
# CTA buttons point to `${NEXT_PUBLIC_APP_URL}/login`.
# Leave this as production, change it to staging, or point it at your own
# local app while editing the landing page in Codespaces.
NEXT_PUBLIC_APP_URL=https://app.openhex.tech

# OpenHex customer-service chat. Local Next.js development proxies the token
# request through www.openhex.tech; set this only when using another backend.
NEXT_PUBLIC_OPENHEX_CHAT_TOKEN_URL=
NEXT_PUBLIC_OPENHEX_AGENT_ID=56941e40-47ad-49b0-bf88-cb8845b06c0e
NEXT_PUBLIC_OPENHEX_API_BASE=https://api.openhex.tech
